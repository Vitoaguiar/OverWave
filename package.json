{
  "name": "overwave",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "description": "OverWave - Advanced Character Draft Builder for Wuthering Waves",
  "author": "OverWave Team",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "npm run build && electron-builder --dir && call \"%LOCALAPPDATA%\\Programs\\Inno Setup 6\\ISCC.exe\" OverWave.iss"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^41.4.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.overwave.app",
    "productName": "OverWave",
    "artifactName": "Overwave-Setup.${ext}",
    "directories": {
      "buildResources": "Icons"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "Icons/**/*",
      "src/data/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OverWave",
      "installerIcon": "Icons/overwaveicon.ico",
      "uninstallerIcon": "Icons/overwaveicon.ico"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "Icons/overwaveicon.ico"
    }
  }
}
